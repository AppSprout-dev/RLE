{
  "permissions": {
    "allow": [
      "Bash(python -m pytest:*)",
      "Bash(pytest:*)",
      "Bash(python -m ruff:*)",
      "Bash(ruff:*)",
      "Bash(python -m mypy:*)",
      "Bash(mypy:*)",
      "Bash(pip install:*)",
      "Bash(pip list:*)",
      "Bash(pip show:*)",
      "Bash(python scripts/*)",
      "Bash(python -c:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git stash:*)",
      "Bash(curl:*)",
      "Bash(OPENAI_API_KEY=*)",
      "Bash(PYTHONIOENCODING=*)",
      "Bash(bun run:*)",
      "Bash(bun install:*)",
      "Bash(uv run:*)",
      "Bash(python -m uv run:*)",
      "Bash(uv pip:*)",
      "Bash(uv sync:*)",
      "Bash(docker compose:*)",
      "Bash(docker build:*)",
      "Bash(docker exec:*)",
      "Bash(dotnet build:*)",
      "Bash(gh pr comment:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "[[ \"$CLAUDE_FILE_PATH\" == *.py ]] && ruff check --fix --quiet \"$CLAUDE_FILE_PATH\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
