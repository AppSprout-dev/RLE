# --- LLM Provider ---
# Provider: "openai" (LM Studio / OpenRouter / OpenAI) or "anthropic"
PROVIDER=openai

# Model name as the provider expects it
MODEL=unsloth/nvidia-nemotron-3-nano-4b

# Base URL for the provider API (required for LM Studio and OpenRouter)
# LM Studio: http://localhost:1234/v1
# OpenRouter: https://openrouter.ai/api/v1
# Anthropic/OpenAI: leave blank (uses default)
PROVIDER_BASE_URL=http://localhost:1234/v1

# --- API Keys (set the one matching your provider) ---
# OpenRouter: your OpenRouter key (auto-bridged to OPENAI_API_KEY)
OPENROUTER_API_KEY=

# LM Studio: any non-empty string works
# OPENAI_API_KEY=lm-studio

# Anthropic: only if using --provider anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# --- RIMAPI (RimWorld mod) ---
RIMAPI_URL=http://localhost:8765
